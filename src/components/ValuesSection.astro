---

---

<section class="py-20 bg-gray-50">
  <div class="container mx-auto px-4">
    <div class="text-center mb-16" data-aos="fade-up">
      <h2 class="text-3xl font-bold font-heading text-primary">
        Nuestros Valores
      </h2>
      <p class="text-gray-600 mt-4 max-w-2xl mx-auto">
        Principios éticos que guían cada una de nuestras acciones y decisiones.
      </p>
    </div>

    <div
      class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 max-w-7xl mx-auto"
    >
      <!-- Reciprocidad -->
      <div
        class="bg-white p-8 rounded-xl shadow-sm border border-gray-100 hover:shadow-md transition-all duration-300 group"
        data-aos="fade-up"
        data-aos-delay="100"
      >
        <div
          class="w-14 h-14 bg-blue-50 text-blue-600 rounded-lg flex items-center justify-center mb-6 group-hover:bg-blue-600 group-hover:text-white transition-colors"
        >
          <!-- Handshake Icon -->
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="w-8 h-8"
          >
            <path
              d="m11 17 2 2a1 1 0 1 0 3-1.47l-10-10a2 2 0 0 0-2.83 0l-1 1a2 2 0 0 0 0 2.83l9 9H21V2h-1a2 2 0 0 0-2 2v2"
            ></path>
            <path d="m22 22-5-10-5 10"></path>
            <path d="M14 14 3 3"></path>
            <path d="M7 17v5"></path>
          </svg>
        </div>
        <h3 class="text-lg font-bold text-gray-900 mb-3">Reciprocidad</h3>
        <p class="text-gray-600 text-sm leading-relaxed">
          Ofrecer bienestar a los colaboradores, al motivar su desempeño, para
          generar y mantener un sentido de pertenencia, compromiso y una
          relación de lealtad.
        </p>
      </div>

      <!-- Trabajo en Equipo -->
      <div
        class="bg-white p-8 rounded-xl shadow-sm border border-gray-100 hover:shadow-md transition-all duration-300 group"
        data-aos="fade-up"
        data-aos-delay="200"
      >
        <div
          class="w-14 h-14 bg-blue-50 text-blue-600 rounded-lg flex items-center justify-center mb-6 group-hover:bg-blue-600 group-hover:text-white transition-colors"
        >
          <!-- Users Icon -->
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="w-8 h-8"
          >
            <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path>
            <circle cx="9" cy="7" r="4"></circle>
            <path d="M22 21v-2a4 4 0 0 0-3-3.87"></path>
            <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
          </svg>
        </div>
        <h3 class="text-lg font-bold text-gray-900 mb-3">Trabajo en Equipo</h3>
        <p class="text-gray-600 text-sm leading-relaxed">
          Cooperar activamente con los compañeros de trabajo, para garantizar el
          cumplimiento de las proyecciones individuales y empresariales.
        </p>
      </div>

      <!-- Servicio -->
      <div
        class="bg-white p-8 rounded-xl shadow-sm border border-gray-100 hover:shadow-md transition-all duration-300 group"
        data-aos="fade-up"
        data-aos-delay="300"
      >
        <div
          class="w-14 h-14 bg-blue-50 text-blue-600 rounded-lg flex items-center justify-center mb-6 group-hover:bg-blue-600 group-hover:text-white transition-colors"
        >
          <!-- Heart/Hand Support Icon -->
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="w-8 h-8"
          >
            <path
              d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"
            ></path>
          </svg>
        </div>
        <h3 class="text-lg font-bold text-gray-900 mb-3">Servicio</h3>
        <p class="text-gray-600 text-sm leading-relaxed">
          Brindar soluciones mediante un análisis detallado de necesidades,
          evaluación de alternativas y acompañamiento permanente y oportuno.
        </p>
      </div>

      <!-- Integridad -->
      <div
        class="bg-white p-8 rounded-xl shadow-sm border border-gray-100 hover:shadow-md transition-all duration-300 group"
        data-aos="fade-up"
        data-aos-delay="400"
      >
        <div
          class="w-14 h-14 bg-blue-50 text-blue-600 rounded-lg flex items-center justify-center mb-6 group-hover:bg-blue-600 group-hover:text-white transition-colors"
        >
          <!-- Shield Icon -->
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="w-8 h-8"
          >
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
          </svg>
        </div>
        <h3 class="text-lg font-bold text-gray-900 mb-3">Integridad</h3>
        <p class="text-gray-600 text-sm leading-relaxed">
          Ser una persona ejemplar, manteniendo un comportamiento recto y
          honrado en cualquier situación.
        </p>
      </div>
    </div>
  </div>
</section>
