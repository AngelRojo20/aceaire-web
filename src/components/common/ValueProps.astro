---
const pillars = [
  {
    title: "Alianzas Estratégicas",
    badge: "Respaldo Global",
    description:
      "Contamos con alianzas sólidas de años con las marcas más reconocidas del mercado global, garantizando acceso a la tecnología más avanzada sin depender de inventarios locales.",
    icon: "handshake",
    link: "/soluciones#constructoras",
    features: [
      "Marcas Líderes Globales",
      "Tecnología de Vanguardia",
      "Respaldo de Fábrica",
    ],
  },
  {
    title: "Ingeniería Integral",
    badge: "Ciclo Completo",
    description:
      "Experiencia certificada desde el diseño conceptual hasta la puesta en marcha. Nuestros ingenieros supervisan cada fase con estándares de precisión técnica, cumplimiento normativo RETIE/RITE y control de calidad.",
    icon: "engineering",
    link: "/soluciones#industria",
    features: [
      "Diseño a Puesta en Marcha",
      "Ingeniería Certificada",
      "Cumplimiento Normativo",
    ],
  },
  {
    title: "El Conocimiento",
    badge: "Nuestra Mayor Ventaja",
    description:
      "Nuestra mayor ventaja competitiva es el conocimiento. Más de 40 años de experiencia técnica nos permiten dimensionar y ejecutar soluciones de ingeniería precisas que otros no pueden visualizar.",
    icon: "brain",
    link: "/nosotros",
    features: [
      "+40 Años de Experiencia",
      "Soluciones a Medida",
      "Visión Técnica Única",
    ],
  },
];
---

<section class="py-24 bg-white relative z-10">
  <div class="container mx-auto px-4">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <span
        class="text-action font-bold uppercase tracking-wider text-sm mb-2 block"
        >Nuestras Verticales</span
      >
      <h2 class="text-3xl md:text-4xl font-bold text-primary font-heading mb-6">
        Ingeniería que Respalda su Operación
      </h2>
      <p class="text-gray-600 text-lg">
        Alianzas globales, ingeniería de precisión y décadas de conocimiento
        técnico al servicio de su proyecto.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-8">
      {
        pillars.map((pillar, index) => (
          <a
            href={pillar.link}
            class="relative bg-white p-8 rounded-2xl shadow-lg border border-gray-100 hover:border-action/30 transition-all duration-300 group hover:-translate-y-2 flex flex-col h-full overflow-hidden"
            data-aos="fade-up"
            data-aos-delay={index * 100}
          >
            {/* Background Icon */}
            <div class="absolute top-4 right-4 opacity-[0.04] group-hover:opacity-[0.08] transition-opacity transform group-hover:scale-125 duration-500 text-primary">
              {pillar.icon === "handshake" && (
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="120"
                  height="120"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="m11 17 2 2a1 1 0 1 0 3-3" />
                  <path d="m14 14 2.5 2.5a1 1 0 1 0 3-3l-3.88-3.88a3 3 0 0 0-4.24 0l-.88.88a1 1 0 1 1-3-3l2.81-2.81a5.79 5.79 0 0 1 7.06-.87l.47.28a2 2 0 0 0 1.42.25L21 4" />
                  <path d="m21 3 1 11h-2" />
                  <path d="M3 3 2 14l6.5 6.5a1 1 0 1 0 3-3" />
                  <path d="M3 4h8" />
                </svg>
              )}
              {pillar.icon === "engineering" && (
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="120"
                  height="120"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M12 3v17.414" />
                  <path d="m6.737 6.737 1.06 1.06" />
                  <path d="M3 12h2" />
                  <path d="m6.737 17.263 1.06-1.06" />
                  <path d="m16.203 6.737-1.06 1.06" />
                  <path d="M19 12h2" />
                  <path d="m16.203 17.263-1.06-1.06" />
                  <circle cx="12" cy="12" r="4" />
                  <circle cx="12" cy="12" r="1" />
                </svg>
              )}
              {pillar.icon === "brain" && (
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="120"
                  height="120"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M12 2a4 4 0 0 0-4 4v1a2 2 0 0 0-2 2v1a3 3 0 0 0 3 3h1" />
                  <path d="M12 2a4 4 0 0 1 4 4v1a2 2 0 0 1 2 2v1a3 3 0 0 1-3 3h-1" />
                  <path d="M9 13a3 3 0 0 0-1 5.236" />
                  <path d="M15 13a3 3 0 0 1 1 5.236" />
                  <path d="M10 18.12a4 4 0 0 0 4 0" />
                  <path d="M12 13v9" />
                </svg>
              )}
            </div>

            {/* Badge */}
            <div class="mb-6">
              <span class="bg-blue-50 text-primary px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wide border border-blue-100">
                {pillar.badge}
              </span>
            </div>

            {/* Icon */}
            <div class="w-14 h-14 rounded-xl bg-primary/5 group-hover:bg-primary group-hover:text-white text-primary flex items-center justify-center mb-6 transition-all duration-300">
              {pillar.icon === "handshake" && (
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="28"
                  height="28"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="m11 17 2 2a1 1 0 1 0 3-3" />
                  <path d="m14 14 2.5 2.5a1 1 0 1 0 3-3l-3.88-3.88a3 3 0 0 0-4.24 0l-.88.88a1 1 0 1 1-3-3l2.81-2.81a5.79 5.79 0 0 1 7.06-.87l.47.28a2 2 0 0 0 1.42.25L21 4" />
                  <path d="m21 3 1 11h-2" />
                  <path d="M3 3 2 14l6.5 6.5a1 1 0 1 0 3-3" />
                  <path d="M3 4h8" />
                </svg>
              )}
              {pillar.icon === "engineering" && (
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="28"
                  height="28"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z" />
                </svg>
              )}
              {pillar.icon === "brain" && (
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="28"
                  height="28"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M9.5 2A2.5 2.5 0 0 1 12 4.5v15a2.5 2.5 0 0 1-4.96.44 2.5 2.5 0 0 1-2.96-3.08 3 3 0 0 1-.34-5.58 2.5 2.5 0 0 1 1.32-4.24 2.5 2.5 0 0 1 1.98-3A2.5 2.5 0 0 1 9.5 2Z" />
                  <path d="M14.5 2A2.5 2.5 0 0 0 12 4.5v15a2.5 2.5 0 0 0 4.96.44 2.5 2.5 0 0 0 2.96-3.08 3 3 0 0 0 .34-5.58 2.5 2.5 0 0 0-1.32-4.24 2.5 2.5 0 0 0-1.98-3A2.5 2.5 0 0 0 14.5 2Z" />
                </svg>
              )}
            </div>

            {/* Title */}
            <h3 class="text-2xl font-bold font-heading text-primary mb-4 group-hover:text-action transition-colors">
              {pillar.title}
            </h3>

            {/* Description */}
            <p class="text-gray-600 mb-8 leading-relaxed flex-grow relative z-10">
              {pillar.description}
            </p>

            {/* Features */}
            <ul class="space-y-2 mb-8 border-t border-gray-100 pt-6">
              {pillar.features.map((feature) => (
                <li class="text-sm text-gray-500 flex items-center gap-2">
                  <span class="text-action">✓</span> {feature}
                </li>
              ))}
            </ul>

            {/* CTA */}
            <div class="mt-auto">
              <span class="text-primary font-bold flex items-center gap-2 text-sm uppercase tracking-wider group-hover:gap-4 transition-all group-hover:text-action">
                Ver Soluciones <span class="text-xl leading-none">&rarr;</span>
              </span>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>
