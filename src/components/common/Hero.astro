---
import { Image } from "astro:assets";
import defaultBgImage from "../../assets/hero-bg.jpg";

interface Props {
  title: string;
  subtitle: string;
  primaryCtaText?: string;
  primaryCtaLink?: string;
  secondaryCtaText?: string;
  secondaryCtaLink?: string;
  backgroundImage?: ImageMetadata;
  minHeight?: string;
}

const {
  title,
  subtitle,
  primaryCtaText,
  primaryCtaLink,
  secondaryCtaText,
  secondaryCtaLink,
  backgroundImage = defaultBgImage,
  minHeight = "min-h-[60vh] md:min-h-[70vh]",
} = Astro.props;
---

<section class={`relative ${minHeight} flex items-center overflow-hidden`}>
  <!-- Optimized LCP Image -->
  <Image
    src={backgroundImage}
    alt={title}
    format="webp"
    width={1920}
    height={1080}
    loading="eager"
    fetchpriority="high"
    class="absolute inset-0 w-full h-full object-cover -z-10 object-center"
  />

  <!-- Gradient Overlay -->
  <div
    class="absolute inset-0 bg-gradient-to-r from-[#0B2B45]/95 via-[#0B2B45]/70 to-[#0B2B45]/30 z-0"
  >
  </div>

  <div class="container mx-auto px-4 relative z-10 pt-20">
    <div
      class="relative z-10 container mx-auto px-4 h-full flex flex-col justify-center"
    >
      <h1
        class="text-4xl md:text-6xl font-bold font-heading text-white mb-6 leading-tight drop-shadow-lg"
        data-aos="fade-up"
      >
        {title}
      </h1>
      <p
        class="text-lg md:text-2xl text-gray-200 mb-8 max-w-2xl font-light drop-shadow-md"
        data-aos="fade-up"
        data-aos-delay="100"
      >
        {subtitle}
      </p>

      {
        primaryCtaText && (
          <div
            class="flex flex-col sm:flex-row gap-4 pt-8"
            data-aos="fade-up"
            data-aos-delay="200"
          >
            <a
              href={primaryCtaLink}
              class="bg-action hover:bg-orange-600 text-white text-center px-8 py-4 rounded-md font-bold text-lg transition-all shadow-lg hover:shadow-xl hover:-translate-y-1"
            >
              {primaryCtaText}
            </a>
            {secondaryCtaText && (
              <a
                href={secondaryCtaLink}
                class="bg-transparent border-2 border-white hover:bg-white/10 text-white text-center px-8 py-4 rounded-md font-bold text-lg transition-all backdrop-blur-sm"
              >
                {secondaryCtaText}
              </a>
            )}
          </div>
        )
      }
    </div>
  </div>

  <!-- Decorative Element -->
  <div
    class="absolute bottom-0 right-0 w-1/3 h-1/3 bg-action/10 blur-3xl rounded-full -mb-20 -mr-20 pointer-events-none z-0"
  >
  </div>
</section>
