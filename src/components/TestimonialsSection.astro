---
import { Image } from "astro:assets";
import vivianaImg from "../assets/team/viviana-torres.jpg";
import marioImg from "../assets/team/mario-torres.jpg";
---

<section class="py-20 bg-white">
  <div class="container mx-auto px-4">
    <div class="text-center mb-16" data-aos="fade-up">
      <h2 class="text-3xl font-bold font-heading text-primary">
        Testimonios Corporativos
      </h2>
      <p class="text-gray-600 mt-4 max-w-2xl mx-auto">
        Historias de crecimiento y compromiso de quienes hacen posible nuestra
        excelencia.
      </p>
    </div>

    <div
      class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-12 max-w-5xl mx-auto"
    >
      <!-- Viviana Torres -->
      <div
        class="bg-gray-50 p-8 md:p-10 rounded-2xl relative group hover:bg-white hover:shadow-lg transition-all duration-300 border border-transparent hover:border-gray-100"
        data-aos="fade-up"
        data-aos-delay="100"
      >
        <!-- Quote Icon -->
        <div
          class="absolute top-8 right-8 text-blue-100 group-hover:text-blue-50 transition-colors"
        >
          <svg
            width="60"
            height="60"
            viewBox="0 0 24 24"
            fill="currentColor"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M14.017 21L14.017 18C14.017 16.8954 14.9124 16 16.017 16H19.017C19.5693 16 20.017 15.5523 20.017 15V9C20.017 8.44772 19.5693 8 19.017 8H15.017C14.4647 8 14.017 8.44772 14.017 9V11C14.017 11.5523 13.5693 12 13.017 12H12.017V5H22.017V15C22.017 18.3137 19.3307 21 16.017 21H14.017ZM5.0166 21L5.0166 18C5.0166 16.8954 5.91203 16 7.0166 16H10.0166C10.5689 16 11.0166 15.5523 11.0166 15V9C11.0166 8.44772 10.5689 8 10.0166 8H6.0166C5.46432 8 5.0166 8.44772 5.0166 9V11C5.0166 11.5523 4.56889 12 4.0166 12H3.0166V5H13.0166V15C13.0166 18.3137 10.3303 21 7.0166 21H5.0166Z"
            ></path>
          </svg>
        </div>

        <div
          class="relative z-10 flex flex-col md:flex-row items-center md:items-start gap-6"
        >
          <div class="flex-shrink-0">
            <Image
              src={vivianaImg}
              alt="Viviana Torres López"
              width={400}
              height={400}
              format="webp"
              quality="high"
              class="w-20 h-20 md:w-24 md:h-24 rounded-full object-cover border-4 border-white shadow-md mx-auto"
            />
          </div>
          <div class="text-center md:text-left">
            <blockquote class="text-gray-600 italic leading-relaxed mb-4">
              "Trabajar en ACE AIRE SAS es una experiencia de vida en donde he
              podido crecer profesional y personalmente... La Compañía me ha
              brindado la oportunidad de aprender a todo nivel... GRACIAS ACE
              AIRE SAS"
            </blockquote>
            <div>
              <h4 class="text-lg font-bold text-primary">
                Viviana Torres López
              </h4>
              <p
                class="text-sm text-gray-500 uppercase tracking-wider font-medium"
              >
                Colaboradora ACE AIRE
              </p>
            </div>
          </div>
        </div>
      </div>

      <!-- Mario Torres -->
      <div
        class="bg-gray-50 p-8 md:p-10 rounded-2xl relative group hover:bg-white hover:shadow-lg transition-all duration-300 border border-transparent hover:border-gray-100"
        data-aos="fade-up"
        data-aos-delay="200"
      >
        <!-- Quote Icon -->
        <div
          class="absolute top-8 right-8 text-blue-100 group-hover:text-blue-50 transition-colors"
        >
          <svg
            width="60"
            height="60"
            viewBox="0 0 24 24"
            fill="currentColor"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M14.017 21L14.017 18C14.017 16.8954 14.9124 16 16.017 16H19.017C19.5693 16 20.017 15.5523 20.017 15V9C20.017 8.44772 19.5693 8 19.017 8H15.017C14.4647 8 14.017 8.44772 14.017 9V11C14.017 11.5523 13.5693 12 13.017 12H12.017V5H22.017V15C22.017 18.3137 19.3307 21 16.017 21H14.017ZM5.0166 21L5.0166 18C5.0166 16.8954 5.91203 16 7.0166 16H10.0166C10.5689 16 11.0166 15.5523 11.0166 15V9C11.0166 8.44772 10.5689 8 10.0166 8H6.0166C5.46432 8 5.0166 8.44772 5.0166 9V11C5.0166 11.5523 4.56889 12 4.0166 12H3.0166V5H13.0166V15C13.0166 18.3137 10.3303 21 7.0166 21H5.0166Z"
            ></path>
          </svg>
        </div>

        <div
          class="relative z-10 flex flex-col md:flex-row items-center md:items-start gap-6"
        >
          <div class="flex-shrink-0">
            <Image
              src={marioImg}
              alt="Mario Torres"
              width={400}
              height={400}
              format="webp"
              quality="high"
              class="w-20 h-20 md:w-24 md:h-24 rounded-full object-cover border-4 border-white shadow-md mx-auto"
            />
          </div>
          <div class="text-center md:text-left">
            <blockquote class="text-gray-600 italic leading-relaxed mb-4">
              "Hace 24 años tomé un camino, el cual no me imaginé que sería la
              mejor experiencia de mi vida... he crecido profesionalmente y cada
              día aprendo más para brindarle a nuestros clientes un servicio
              cargado de experiencia y conocimiento..."
            </blockquote>
            <div>
              <h4 class="text-lg font-bold text-primary">Mario Torres</h4>
              <p
                class="text-sm text-gray-500 uppercase tracking-wider font-medium"
              >
                Colaborador ACE AIRE
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
