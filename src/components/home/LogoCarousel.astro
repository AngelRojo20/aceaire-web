---
import { Image } from "astro:assets";
import lgLogo from "../../assets/brands/lg.png";
import daikinLogo from "../../assets/brands/daikin.png";
import samsungLogo from "../../assets/brands/samsung.png";
import yorkLogo from "../../assets/brands/york.png";
import mideaLogo from "../../assets/brands/midea.png";
import boschLogo from "../../assets/brands/bosch.png";
import traneLogo from "../../assets/brands/trane.png";

// Logos loaded from src/assets (optimized by Astro)
const astroLogos = [
  { name: "LG", img: lgLogo, class: "!w-2/3 !h-auto" },
  { name: "Daikin", img: daikinLogo, class: "h-16" },
  { name: "Samsung", img: samsungLogo, class: "h-14" },
  { name: "York", img: yorkLogo, class: "!w-3/4 !h-auto" },
  { name: "Midea", img: mideaLogo, class: "h-16" },
  { name: "Bosch", img: boschLogo, class: "h-16" },
  { name: "Trane", img: traneLogo, class: "!w-2/3 !h-auto" },
];
---

<section
  class="py-16 bg-white overflow-hidden border-b border-gray-100 relative group"
>
  <!-- Gradient Masks for Smooth Edges -->
  <div
    class="absolute inset-y-0 left-0 w-24 bg-gradient-to-r from-white to-transparent z-10 pointer-events-none"
  >
  </div>
  <div
    class="absolute inset-y-0 right-0 w-24 bg-gradient-to-l from-white to-transparent z-10 pointer-events-none"
  >
  </div>

  <div class="container mx-auto px-4 text-center mb-10">
    <p class="text-xl font-bold text-gray-400 uppercase tracking-widest">
      Marcas que Acompañan Nuestra Experiencia
    </p>
  </div>

  <div class="w-full overflow-hidden">
    <div
      class="animate-bounce-scroll flex items-center gap-16 px-4 w-max hover:pause"
    >
      {/* First pass: Astro-optimized logos */}
      {
        astroLogos.map((logo) => (
          <div class="flex-shrink-0 w-40 md:w-52 flex justify-center items-center">
            <Image
              src={logo.img}
              alt={`Aliado Estratégico ${logo.name}`}
              loading="lazy"
              class={`w-auto object-contain grayscale opacity-60 hover:grayscale-0 hover:opacity-100 transition-all duration-300 ${logo.class || "h-16"}`}
            />
          </div>
        ))
      }

      {/* Duplicate for seamless scroll */}
      {
        astroLogos.map((logo) => (
          <div class="flex-shrink-0 w-40 md:w-52 flex justify-center items-center">
            <Image
              src={logo.img}
              alt={`Aliado Estratégico ${logo.name}`}
              loading="lazy"
              class={`w-auto object-contain grayscale opacity-60 hover:grayscale-0 hover:opacity-100 transition-all duration-300 ${logo.class || "h-16"}`}
            />
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  @keyframes bounce-scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(calc(-100% + 100vw));
    }
  }

  @keyframes bounce-scroll-smart {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(calc(-50%));
    }
  }

  .animate-bounce-scroll {
    animation: bounce-scroll-smart 30s linear infinite alternate;
  }

  .hover\:pause:hover {
    animation-play-state: paused;
  }
</style>
