---

---

<section class="py-24 bg-slate-50 relative overflow-hidden" id="why-choose-us">
  <div class="container mx-auto px-4">
    <!-- Header -->
    <div class="text-center mb-16" data-aos="fade-up">
      <h2
        class="text-3xl md:text-4xl font-bold font-heading text-primary inline-block relative pb-4"
      >
        Ingeniería con Propósito
        <span
          class="absolute bottom-0 left-1/2 transform -translate-x-1/2 w-24 h-1 bg-action rounded-full"
        ></span>
      </h2>
      <p class="text-gray-600 mt-4 max-w-2xl mx-auto text-lg">
        Empresa sólida, experta y confiable que acompaña al cliente en todo el
        ciclo de vida del proyecto.
      </p>
    </div>

    <!-- Grid de 4 Pilares -->
    <div
      class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-8 mb-16"
    >
      <!-- Pilar 1: Experiencia Certificada -->
      <div
        class="bg-white p-8 rounded-2xl shadow-sm border border-gray-100 transition-all duration-300 hover:-translate-y-2 hover:shadow-xl group"
        data-aos="fade-up"
        data-aos-delay="100"
      >
        <div
          class="w-14 h-14 rounded-xl bg-blue-50 flex items-center justify-center mb-6 group-hover:bg-primary group-hover:text-white transition-colors text-primary"
        >
          <!-- Shield Check icon -->
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="28"
            height="28"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path
              d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"
            ></path>
            <path d="m9 12 2 2 4-4"></path>
          </svg>
        </div>
        <h3 class="text-lg font-bold text-primary mb-3 font-heading">
          Experiencia Certificada
        </h3>
        <p class="text-gray-600 text-sm leading-relaxed">
          Ingenieros expertos a cargo de cada proyecto, garantizando calidad
          desde el <strong class="text-gray-700">diseño conceptual</strong> hasta
          la <strong class="text-gray-700">puesta en marcha</strong>. Cada fase
          es supervisada con estándares de precisión técnica.
        </p>
      </div>

      <!-- Pilar 2: Infraestructura y Ética -->
      <div
        class="bg-white p-8 rounded-2xl shadow-sm border border-gray-100 transition-all duration-300 hover:-translate-y-2 hover:shadow-xl group"
        data-aos="fade-up"
        data-aos-delay="200"
      >
        <div
          class="w-14 h-14 rounded-xl bg-blue-50 flex items-center justify-center mb-6 group-hover:bg-primary group-hover:text-white transition-colors text-primary"
        >
          <!-- Building icon -->
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="28"
            height="28"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <rect width="16" height="20" x="4" y="2" rx="2" ry="2"></rect>
            <path d="M9 22v-4h6v4"></path>
            <path d="M8 6h.01"></path>
            <path d="M16 6h.01"></path>
            <path d="M12 6h.01"></path>
            <path d="M12 10h.01"></path>
            <path d="M12 14h.01"></path>
            <path d="M16 10h.01"></path>
            <path d="M16 14h.01"></path>
            <path d="M8 10h.01"></path>
            <path d="M8 14h.01"></path>
          </svg>
        </div>
        <h3 class="text-lg font-bold text-primary mb-3 font-heading">
          Infraestructura y Ética
        </h3>
        <p class="text-gray-600 text-sm leading-relaxed">
          Compromiso con <strong class="text-gray-700">procesos éticos</strong> y
          la infraestructura técnica necesaria para proyectos de gran escala. Operamos
          bajo estándares de
          <strong class="text-gray-700"
            >responsabilidad social y ambiental</strong
          >
          innegociables.
        </p>
      </div>

      <!-- Pilar 3: Liderazgo Nacional -->
      <div
        class="bg-white p-8 rounded-2xl shadow-sm border border-gray-100 transition-all duration-300 hover:-translate-y-2 hover:shadow-xl group"
        data-aos="fade-up"
        data-aos-delay="300"
      >
        <div
          class="w-14 h-14 rounded-xl bg-blue-50 flex items-center justify-center mb-6 group-hover:bg-primary group-hover:text-white transition-colors text-primary"
        >
          <!-- Trophy icon -->
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="28"
            height="28"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"></path>
            <path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"></path>
            <path d="M4 22h16"></path>
            <path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"
            ></path>
            <path
              d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"
            ></path>
            <path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"></path>
          </svg>
        </div>
        <h3 class="text-lg font-bold text-primary mb-3 font-heading">
          Liderazgo Nacional
        </h3>
        <p class="text-gray-600 text-sm leading-relaxed">
          <strong class="text-gray-700"
            >Referente en el sector HVAC en Colombia</strong
          >
          con más de 40 años conectando al país con las mejores marcas globales. Líderes
          en ventas y ejecución técnica a nivel nacional.
        </p>
      </div>

      <!-- Pilar 4: Factor Humano -->
      <div
        class="bg-white p-8 rounded-2xl shadow-sm border border-gray-100 transition-all duration-300 hover:-translate-y-2 hover:shadow-xl group"
        data-aos="fade-up"
        data-aos-delay="400"
      >
        <div
          class="w-14 h-14 rounded-xl bg-blue-50 flex items-center justify-center mb-6 group-hover:bg-primary group-hover:text-white transition-colors text-primary"
        >
          <!-- Users/Heart icon -->
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="28"
            height="28"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path>
            <circle cx="9" cy="7" r="4"></circle>
            <path d="M22 21v-2a4 4 0 0 0-3-3.87"></path>
            <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
          </svg>
        </div>
        <h3 class="text-lg font-bold text-primary mb-3 font-heading">
          Factor Humano
        </h3>
        <p class="text-gray-600 text-sm leading-relaxed">
          Nuestro equipo es el <strong class="text-gray-700"
            >motor de cada solución técnica</strong
          >, aportando valor humano a la ingeniería de precisión. Invertimos en
          formación y bienestar, impactando positivamente en sus familias y en
          nuestro servicio.
        </p>
      </div>
    </div>

    <!-- CTA Button -->
    <div class="text-center" data-aos="fade-up" data-aos-delay="500">
      <a
        href="/nosotros"
        class="inline-flex items-center justify-center px-8 py-4 bg-primary text-white font-bold rounded-full hover:bg-white hover:text-primary border-2 border-transparent hover:border-primary transition-all duration-300 shadow-md hover:shadow-lg group"
      >
        <span>Conoce Nuestra Trayectoria</span>
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="ml-2 group-hover:translate-x-1 transition-transform"
        >
          <path d="M5 12h14"></path>
          <path d="m12 5 7 7-7 7"></path>
        </svg>
      </a>
    </div>
  </div>
</section>
