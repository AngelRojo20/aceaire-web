---
// Sectores Foco – Home Page
const sectores = [
  {
    title: "Sector Hospitalario",
    description:
      "Climatización para áreas críticas con cumplimiento de normas técnicas. Diseñamos sistemas de aire 100% exterior, presión positiva y filtración HEPA para quirófanos, UCIs y laboratorios.",
    icon: "hospital",
    highlight: "Cumplimiento de normas técnicas",
  },
  {
    title: "Data Centers",
    description:
      "Continuidad operativa y climatización crítica para centros de datos. Sistemas de precisión con redundancia N+1 que garantizan la estabilidad térmica de su infraestructura digital.",
    icon: "server",
    highlight: "Continuidad operativa 24/7",
  },
  {
    title: "Industrial y Comercial",
    description:
      "Soluciones de gran escala para plantas de producción, bodegas logísticas y edificios corporativos. Ventilación mecánica, chillers y sistemas VRF de alta capacidad.",
    icon: "factory",
    highlight: "Proyectos de gran escala",
  },
  {
    title: "Proyectos Residenciales",
    description:
      "Ventilación mecánica de sótanos y sistemas residenciales premium. Diseño e instalación de equipos de alta eficiencia para conjuntos, torres y viviendas de lujo.",
    icon: "home",
    highlight: "Ventilación mecánica de sótanos",
  },
];
---

<section class="py-20 md:py-28 bg-white">
  <div class="container mx-auto px-4">
    <!-- Section Header -->
    <div class="text-center mb-16" data-aos="fade-up">
      <div
        class="inline-block px-4 py-1.5 bg-blue-50 text-primary text-xs font-bold uppercase tracking-widest rounded-full mb-4"
      >
        Nuestros Sectores
      </div>
      <h2 class="text-3xl md:text-4xl font-bold font-heading text-primary">
        Especialistas en Soluciones<br class="hidden sm:inline" /> de Alta Complejidad
      </h2>
      <p class="text-gray-600 mt-4 max-w-2xl mx-auto text-lg">
        Cada sector tiene exigencias únicas. Nuestra ingeniería se adapta a las
        normativas y estándares más rigurosos del mercado.
      </p>
    </div>

    <!-- Sectores Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-8">
      {
        sectores.map((sector, index) => (
          <div
            class="group relative bg-white rounded-2xl p-8 border border-gray-100 hover:border-primary/20 hover:shadow-xl transition-all duration-300 hover:-translate-y-1"
            data-aos="fade-up"
            data-aos-delay={index * 100}
          >
            {/* Icon */}
            <div class="w-14 h-14 rounded-xl bg-primary/5 group-hover:bg-primary group-hover:text-white text-primary flex items-center justify-center mb-6 transition-all duration-300">
              {sector.icon === "hospital" && (
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="28"
                  height="28"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M22 12h-4l-3 9L9 3l-3 9H2" />
                </svg>
              )}
              {sector.icon === "server" && (
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="28"
                  height="28"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <rect width="20" height="8" x="2" y="2" rx="2" ry="2" />
                  <rect width="20" height="8" x="2" y="14" rx="2" ry="2" />
                  <line x1="6" x2="6.01" y1="6" y2="6" />
                  <line x1="6" x2="6.01" y1="18" y2="18" />
                </svg>
              )}
              {sector.icon === "factory" && (
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="28"
                  height="28"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M2 20a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V8l-7 5V8l-7 5V4a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2Z" />
                  <path d="M17 18h1" />
                  <path d="M12 18h1" />
                  <path d="M7 18h1" />
                </svg>
              )}
              {sector.icon === "home" && (
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="28"
                  height="28"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
                  <polyline points="9 22 9 12 15 12 15 22" />
                </svg>
              )}
            </div>

            {/* Content */}
            <h3 class="text-xl font-bold font-heading text-primary mb-3 group-hover:text-primary transition-colors">
              {sector.title}
            </h3>

            {/* Highlight Badge */}
            <span class="inline-block px-3 py-1 bg-action/10 text-action text-xs font-semibold rounded-full mb-4">
              {sector.highlight}
            </span>

            <p class="text-gray-600 text-sm leading-relaxed">
              {sector.description}
            </p>

            {/* Hover accent line */}
            <div class="absolute bottom-0 left-8 right-8 h-0.5 bg-action scale-x-0 group-hover:scale-x-100 transition-transform duration-300 origin-left rounded-full" />
          </div>
        ))
      }
    </div>

    <!-- CTA -->
    <div class="text-center mt-14" data-aos="fade-up" data-aos-delay="400">
      <a
        href="/soluciones"
        class="inline-flex items-center gap-2 text-primary font-bold hover:text-action transition-colors group text-lg"
      >
        Explorar Todas las Soluciones
        <span class="group-hover:translate-x-1 transition-transform">→</span>
      </a>
    </div>
  </div>
</section>
