---

---

<section class="py-24 bg-white relative">
  <!-- Soft Transition CTA -->
  <div class="container mx-auto px-4 mb-20 text-center">
    <div
      class="max-w-3xl mx-auto bg-blue-50/50 rounded-2xl p-8 border border-blue-100"
    >
      <h2 class="text-2xl md:text-3xl font-bold font-heading text-primary mb-4">
        ¿Tiene un proyecto en mente?
      </h2>
      <p class="text-gray-600 text-lg mb-0">
        Permítanos asesorarlo con nuestra ingeniería experta. Diseñamos
        soluciones a la medida de su infraestructura.
      </p>
    </div>
  </div>

  <div class="container mx-auto px-4" data-aos="fade-in">
    <div class="grid md:grid-cols-2 gap-12 lg:gap-20 items-stretch">
      <!-- Left Column: Contact Form -->
      <div
        class="bg-white p-6 md:p-8 rounded-2xl shadow-sm border border-gray-100 flex flex-col h-full"
      >
        <h3 class="text-2xl font-bold font-heading text-primary mb-6">
          Solicitud de Información
        </h3>
        <form class="space-y-6 flex-grow">
          <div>
            <label
              for="name"
              class="block text-sm font-medium text-gray-700 mb-2"
              >Nombre Completo</label
            >
            <input
              type="text"
              id="name"
              name="name"
              class="w-full px-4 py-3 rounded-md border border-gray-300 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all bg-gray-50 focus:bg-white"
              placeholder="Su nombre o empresa"
              required
            />
          </div>

          <div class="grid md:grid-cols-2 gap-6">
            <div>
              <label
                for="email"
                class="block text-sm font-medium text-gray-700 mb-2"
                >Correo Electrónico</label
              >
              <input
                type="email"
                id="email"
                name="email"
                class="w-full px-4 py-3 rounded-md border border-gray-300 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all bg-gray-50 focus:bg-white"
                placeholder="ejemplo@empresa.com"
                required
              />
            </div>
            <div>
              <label
                for="phone"
                class="block text-sm font-medium text-gray-700 mb-2"
                >Teléfono / Celular</label
              >
              <input
                type="tel"
                id="phone"
                name="phone"
                class="w-full px-4 py-3 rounded-md border border-gray-300 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all bg-gray-50 focus:bg-white"
                placeholder="+57 "
                required
              />
            </div>
          </div>

          <div>
            <label
              for="message"
              class="block text-sm font-medium text-gray-700 mb-2"
              >Detalle de su Proyecto</label
            >
            <textarea
              id="message"
              name="message"
              rows="4"
              class="w-full px-4 py-3 rounded-md border border-gray-300 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all bg-gray-50 focus:bg-white resize-none"
              placeholder="Describa brevemente sus requerimientos..."
              required></textarea>
          </div>

          <div class="flex items-start gap-3">
            <div class="flex items-center h-5">
              <input
                id="privacy-policy-home"
                name="privacy"
                type="checkbox"
                class="w-4 h-4 rounded border-gray-300 text-primary focus:ring-primary focus:ring-2 invalid:border-red-500 invalid:text-red-600 focus:invalid:border-red-500 focus:invalid:ring-red-500"
                required
              />
            </div>
            <label
              for="privacy-policy-home"
              class="text-sm text-gray-600 cursor-pointer"
            >
              Autorizo el tratamiento de mis datos personales según la <a
                href="/politica-de-privacidad"
                class="text-primary hover:underline font-medium"
                >Ley 1581 de 2012</a
              > y la <a
                href="/politica-de-privacidad"
                class="text-primary hover:underline font-medium"
                >política de privacidad</a
              > de ACE AIRE S.A.S.
            </label>
          </div>

          <button
            type="submit"
            class="w-full bg-primary hover:bg-blue-900 text-white font-bold py-4 rounded-md transition-all shadow-md hover:shadow-lg transform hover:-translate-y-0.5 text-lg mt-2"
          >
            Enviar Solicitud
          </button>
        </form>
      </div>

      <!-- Right Column: Info Block -->
      <div class="space-y-10 py-4 flex flex-col justify-center">
        <div>
          <h3 class="text-3xl font-bold font-heading text-primary mb-6">
            Contáctenos
          </h3>
          <p class="text-gray-600 leading-relaxed text-lg">
            Estamos listos para atender sus requerimientos de climatización y
            refrigeración a nivel nacional.
          </p>
        </div>

        <div class="space-y-8">
          <!-- Cobertura -->
          <div class="flex items-start gap-4">
            <div class="bg-blue-50 p-3 rounded-lg text-2xl text-primary">
              📍
            </div>
            <div>
              <h4 class="font-bold text-primary text-lg mb-2">
                Cobertura Nacional
              </h4>
              <p class="text-gray-600">
                Operación logística centralizada y sedes estratégicas:
              </p>
              <ul class="mt-2 text-gray-600 space-y-1 font-medium">
                <li>• Bogotá D.C.</li>
                <li>• Funza (Celta Trade Park)</li>
                <li>• Girardot</li>
              </ul>
            </div>
          </div>

          <!-- Telefonos -->
          <div class="flex items-start gap-4">
            <div class="bg-blue-50 p-3 rounded-lg text-2xl text-primary">
              📞
            </div>
            <div class="w-full">
              <h4 class="font-bold text-primary text-lg mb-2">
                Líneas de Atención
              </h4>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-2">
                <a
                  href="tel:+573112727664"
                  class="text-gray-600 hover:text-action transition-colors block"
                >
                  Cel: <span class="font-medium">311 272 7664</span>
                </a>
                <a
                  href="tel:+573112793644"
                  class="text-gray-600 hover:text-action transition-colors block"
                >
                  Cel: <span class="font-medium">311 279 3644</span>
                </a>
                <a
                  href="tel:+573112027807"
                  class="text-gray-600 hover:text-action transition-colors block"
                >
                  Cel: <span class="font-medium">311 202 7807</span>
                </a>
                <a
                  href="tel:+573202285812"
                  class="text-gray-600 hover:text-action transition-colors block"
                >
                  Cel: <span class="font-medium">320 228 5812</span>
                </a>
                <a
                  href="tel:+576016306223"
                  class="text-gray-600 hover:text-action transition-colors block sm:col-span-2 mt-1"
                >
                  Fijo: <span class="font-medium">(601) 630 6223</span>
                </a>
              </div>
            </div>
          </div>

          <!-- Email -->
          <div class="flex items-start gap-4">
            <div class="bg-blue-50 p-3 rounded-lg text-2xl text-primary">
              📧
            </div>
            <div>
              <h4 class="font-bold text-primary text-lg mb-2">
                Correo Corporativo
              </h4>
              <a
                href="mailto:ventas@aceaire.com"
                class="text-lg text-gray-600 font-medium hover:text-action transition-colors"
              >
                ventas@aceaire.com
              </a>
            </div>
          </div>

          <!-- Social -->
          <div class="pt-6 border-t border-gray-100">
            <h4
              class="font-bold text-primary text-sm uppercase tracking-wide mb-4"
            >
              Síguenos en redes
            </h4>
            <div class="flex gap-4">
              <a
                href="https://www.facebook.com/AceAireSas"
                target="_blank"
                rel="noopener noreferrer"
                class="bg-primary text-white p-3 rounded-full hover:bg-action transition-colors"
                aria-label="Facebook"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  ><path
                    d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"
                  ></path></svg
                >
              </a>
              <a
                href="https://www.instagram.com/aceairesas/?hl=af"
                target="_blank"
                rel="noopener noreferrer"
                class="bg-primary text-white p-3 rounded-full hover:bg-action transition-colors"
                aria-label="Instagram"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  ><rect width="20" height="20" x="2" y="2" rx="5" ry="5"
                  ></rect><path
                    d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"
                  ></path><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"
                  ></line></svg
                >
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
